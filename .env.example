# Google Maps API Configuration
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend API Configuration
VITE_API_URL=http://localhost:3001/api

# Cloudinary Image Uploads (optional but recommended)
# Get these from https://cloudinary.com/console
# Cloud name: shown on the dashboard ("Cloud name").
# Upload preset: Settings → Upload → Add upload preset (must be UNSIGNED).
# When set, image uploads in Admin go directly to Cloudinary and only the
# URL is stored in Firestore. If empty, the app falls back to local
# compression + base64 (backwards compatible).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_FOLDER=kingaroos
