# Backend API Configuration
VITE_API_URL=https://kingaroos-backend.onrender.com/api

# Note: Google Maps embed is used instead of API, so no API key needed

# Cloudinary Image Uploads
# Cloud name from https://console.cloudinary.com/ dashboard
VITE_CLOUDINARY_CLOUD_NAME=dlpte3bb5
# Unsigned upload preset name (create in Cloudinary Settings -> Upload -> Upload presets)
VITE_CLOUDINARY_UPLOAD_PRESET=kingaroos_unsigned
# Folder where uploaded images will be stored in your Cloudinary library
VITE_CLOUDINARY_FOLDER=kingaroos
